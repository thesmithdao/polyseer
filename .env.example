# ── Agent identity ─────────────────────────────────────────────
# A fixed seed gives the agent a stable address across restarts. CHANGE THIS.
AGENT_SEED=change-me-to-a-long-random-string
# Port to bind. Railway injects PORT automatically; 8000 is fine locally.
PORT=8000
# Connection mode:
#  - Leave AGENT_ENDPOINT unset  -> MAILBOX agent (outbound; pair via inspector link).
#  - Set it to your public URL + /submit -> ENDPOINT agent (register the URL on Agentverse).
# On Railway: Settings -> Networking -> Generate Domain, then:
# AGENT_ENDPOINT=https://your-app.up.railway.app/submit

# ── LLM backend ────────────────────────────────────────────────
# One of: asi1 (default) | anthropic | openai
LLM_PROVIDER=asi1

# asi1 (ASI:One — get a key at https://asi1.ai)
ASI_ONE_API_KEY=
ASI_ONE_MODEL=asi1-mini
# ASI_ONE_BASE_URL=https://api.asi1.ai/v1

# anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# openai / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=
